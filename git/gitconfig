# ~/git/.gitconfig

# gpg as ssh format
[gpg]
    format = ssh

# use nvim as editor
[core]
    editor = nvim

# always sign git commits
[commit]
    gpgsign = true

# always use main as default branch
[init]
    defaultBranch = main

# user config
[user]
    name = "Sarvagya Sagar"
    signingkey = "~/.ssh/github/sign.pub"
    email = "186076145+s4rv4gy4@users.noreply.github.com"

# gpg ssh
[gpg "ssh"]
    allowedSignersFile = "~/.ssh/github/allowed_signers"
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
